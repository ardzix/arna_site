# ============================================================
# ArnaSite — Environment Configuration Example (Production)
# ============================================================

# ---- Django Core ----
SECRET_KEY=your-secret-key-here
DEBUG=False

# ---- Allowed Hosts ----
# Comma-separated list of domains that Django will serve.
# Include the wildcard prefix for tenant subdomains.
ALLOWED_HOSTS=ALLOWED_HOSTS=.arnasite.id,.arnatech.id,site.arnatech.id,172.105.124.43,.site.arnatech.id

# ---- PostgreSQL Database ----
DB_ENGINE=django.db.backends.postgresql
DB_NAME=arna_site_db
DB_USER=postgres
DB_PASSWORD=your-db-password-here
DB_HOST=127.0.0.1
DB_PORT=5432

# ---- Redis (used for SSO user cache) ----
REDIS_URL=redis://redis:6379/1

# ---- Arna SSO Integration ----
# Base URL of the Arna SSO service API (no trailing slash)
ARNA_SSO_BASE_URL=https://sso.arnatech.id/api
# Enable/disable automatic SSO IAM provisioning on tenant registration
SSO_IAM_PROVISION_ON_REGISTER=True

# How long (in seconds) to cache the SSO /auth/me response per token
SSO_USER_CACHE_TTL=300

# ---- Arna File Manager (Storage) Integration ----
# Base URL of the Arna File Manager service (no trailing slash)
ARNA_STORAGE_BASE_URL=https://storage.arnatech.id

# ---- CORS ----
# Comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=https://app.arnasite.id,https://admin.arnasite.id
# Allow credentialed requests (cookies/auth headers) in cross-origin calls
CORS_ALLOW_CREDENTIALS=True

# ---- JWT Public Key Path ----
# Path to the public key file used for JWT verification
SSO_JWT_PUBLIC_KEY_PATH=/app/ssl/public.pem
SSO_JWT_AUDIENCE=
